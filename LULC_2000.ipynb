var crs = 'EPSG:4326'; 
var scale = 30;


// Resample function for continuous layers (bilinear)
function resampleContinuous(img) {
  return img.resample('bilinear').reproject({
    crs: crs,
    scale: scale
  });
}

// Resample function for categorical layers (nearest)
function resampleCategorical(img) {
  return img.resample('nearest').reproject({
    crs: crs,
    scale: scale
  });
}

