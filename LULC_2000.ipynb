  trnclassifier = ee.Classifier.smileRandomForest({
    numberOfTrees: 100,
    variablesPerSplit: null,
    minLeafPopulation: 1,
    maxNodes: 1000,
    bagFraction: 0.5,
    seed: 0
  }).train({
    features: trnSample,
    classProperty: 'class',
    inputProperties: bands       // or afterFloodBands.bandNames()
  });
} else if (classifierType === 'GBM') {
  // Train a Gradient Boosting Machine classifier
  trnclassifier = ee.Classifier.smileGradientTreeBoost({
    numberOfTrees: 100
  }).train({
    features: trnSample,
    classProperty: 'class',
    inputProperties: bands       // or afterFloodBands.bandNames()
  });
} else if (classifierType === 'KNN') {
  // Train a K-Nearest Neighbors classifier
  trnclassifier = ee.Classifier.smileKNN({
    numberOfNeighbors: 5,       // Adjust as needed
    weightType: 'distance',     // You can use 'uniform' or 'distance'
    maxNeighbors: 10            // Maximum number of neighbors to consider
  }).train({
    features: trnSample,
    classProperty: 'class',
    inputProperties: bands      // or afterFloodBands.bandNames()
  });
} else if (classifierType === 'NB') {
  // Train a Naive Bayes classifier
  trnclassifier = ee.Classifier.smileNaiveBayes().train({
    features: trnSample,
    classProperty: 'class',
    inputProperties: bands      // or afterFloodBands.bandNames()
  });
} else if (classifierType === 'SVM') {
  // Train a Support Vector Machine classifier
  trnclassifier = ee.Classifier.libsvm().train({
    features: trnSample,
    classProperty: 'class',
    inputProperties: bands     // or afterFloodBands.bandNames()
  });
} else {
  print('Invalid classifier type. Please choose either "RF", "GBM", "KNN", "NB", or "SVM".');
}

