//============================================================================================================


// Normalize single band with percentile clipping
function normalizeBandTo01(img, bandName, AOI) {
  var band = img.select(bandName);
  var perc = band.reduceRegion({
    reducer: ee.Reducer.percentile([2, 98]),
    geometry: AOI,
    scale: 30,
    maxPixels: 1e13,
    bestEffort: true
  });
  var p2 = ee.Number(perc.get(bandName + '_p2'));
  var p98 = ee.Number(perc.get(bandName + '_p98'));
  // avoid division by zero
  var denom = p98.subtract(p2).max(1e-9);
  var norm = band.subtract(p2).divide(denom).clamp(0, 1)
                 .rename(bandName ); // bandName + '_n'
  return img.addBands(norm, null, true);
}

// Example: normalize elevation, slope, hand1
var aux = ee.Image().select(); // start empty
aux = aux.addBands(elevation).addBands(slope).addBands(hand1);

// map over band names to add normalized versions
var bandNames = ['elevation','slope','hand1','builtUp', 'distRoad'];
bandNames.forEach(function(b){
  aux = normalizeBandTo01(aux, b, AOI);
});





